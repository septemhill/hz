// Practical malloc usage example with error handling
// This example demonstrates safe dynamic memory allocation using malloc/free
// Includes error handling for malloc failure cases using external helpers

import "io"

// Declare external C functions for memory allocation
extern fn malloc(size: u64) rawptr;
extern fn free(ptr: rawptr) rawptr;

// memset to write to memory
extern fn memset(ptr: rawptr, value: i32, size: u64) rawptr;

// memcpy to copy memory  
extern fn memcpy(dest: rawptr, src: rawptr, size: u64) rawptr;

fn safe_free(ptr: *rawptr) rawptr {
    free(ptr.*);
    ptr.* = @bit_cast(0, rawptr);
}

struct Point {
    x: i32,
    y: i64,
}

fn alloc(size: u64) *Point {
    const p = malloc(size);
    return @bit_cast(p, *Point);
}

fn main() i32 {
    io.println("Point allocation")
    var p = alloc(@size_of(Point));
    p.*.x = 123;
    p.*.y = 444;
    io.println("p.x: {d}, p.y: {d}", p.*.x, p.*.y);
    io.println("");
    
    io.println("=== Malloc Error Handling Test ===");
    io.println("With NULL pointer checking");
    io.println("");
    
    var all_ok: bool = true;
    
    // Test 1: Allocate memory with error handling
    io.println("Test 1: Allocating 8 bytes...");
    var ptr1: rawptr = malloc(8);
    
    // Check if allocation succeeded
    if (@is_not_null(ptr1)) {
        io.println("  Allocation: SUCCESS");
        memset(ptr1, 97, 8);
        io.println("  Write: OK");
        safe_free(&ptr1);
        io.println("  Freed");
    } else {
        io.println("  Allocation: FAILED!");
        all_ok = false;
    }

    io.println("ptr1 is null: {b}", @is_null(ptr1));
    io.println("ptr1 is not null: {b}", @is_not_null(ptr1));
    
    // Test 2: Allocate for string storage
    io.println("Test 2: Allocating 256 bytes...");
    var ptr2: rawptr = malloc(256);
    
    if (@is_not_null(ptr2)) {
        io.println("  Allocation: SUCCESS");
        memset(ptr2, 65, 256);
        io.println("  Write: OK");
    } else {
        io.println("  Allocation: FAILED!");
        all_ok = false;
    }
    
    // Test 3: Allocate large memory
    io.println("Test 3: Allocating 1MB...");
    var large_ptr: rawptr = malloc(1048576);
    
    if (@is_not_null(large_ptr)) {
        io.println("  Allocation: SUCCESS");
        memset(large_ptr, 66, 1024);
        io.println("  Write: OK");
        safe_free(&large_ptr);
        io.println("  Memory freed");
    } else {
        io.println("  Allocation: FAILED!");
        all_ok = false;
    }
    
    // Test 4: Multiple allocations
    io.println("Test 4: Multiple allocations...");
    var src: rawptr = malloc(64);
    var dest: rawptr = malloc(64);
    
    if (@is_not_null(src) && @is_not_null(dest)) {
        io.println("  Both allocations: SUCCESS");
        memset(src, 66, 64);
        memcpy(dest, src, 64);
        io.println("  Operations: OK");
    } else {
        io.println("  Allocation: FAILED!");
        all_ok = false;
    }
    
    // Clean up - only free valid pointers
    io.println("");
    io.println("Cleanup phase:");
    
    if (@is_not_null(ptr1)) {
        io.println("1");
        safe_free(&ptr1);
        io.println("  Freed ptr1");
    }
    
    if (@is_not_null(ptr2)) {
        safe_free(&ptr2);
        io.println("  Freed ptr2");
    }
    
    if (@is_not_null(src)) {
        safe_free(&src);
        io.println("  Freed src");
    }
    
    if (@is_not_null(dest)) {
        safe_free(&dest)
        io.println("  Freed dest");
    }
    
    io.println("");
    
    // Final result
    if (all_ok) {
        io.println("=== ALL TESTS PASSED ===");
        return 0;
    } else {
        io.println("=== SOME TESTS FAILED ===");
        return 1;
    }
}
