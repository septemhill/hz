import "io"

pub interface TemplateBase {
    MethodOne() void,
    MethodTwo() void,
}

pub interface TemplateMath {
    MethodThree(i64, i64) i64,
}

pub interface Template {
    TemplateBase,
    TemplateMath,
}

pub struct Service {
    impl Template {
        fn MethodOne(self: Self) void {
            io.println("MethodOne");
        }

        fn MethodTwo(self: Self) void {
            io.println("MethodTwo");
        }

        fn MethodThree(self: Self, a: i64, b: i64) i64 {
            return a + b;
        }
    }
}

pub fn validate<T: Template>(service: T) void {
    service.MethodOne();
    service.MethodTwo();
    const total = service.MethodThree(1, 2);
    io.println(total);
}

fn main() void {
    const service = Service {
    };

    validate(service);
}
