    name: String,
    age: i32,

    pub fn MethodOne() {
        io.println("MethodOne");
    }

    pub fn MethodTwo() {
        io.println("MethodTwo");
    }

    pub fn MethodThree(a: i32, b: i64) i64 {
        return a + b;
    }
};

pub fn validate(srv: Template) {
    service.MethodOne();
    service.MethodTwo();
