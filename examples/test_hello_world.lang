import "io"

fn main() void {
    io.println("Hello World");
    io.println("Hi, {s}", "Septem");
    io.println("Height: {d}, Weight: {f}", 180, 74.3);
    io.println("Hex Code: {x}", 123);

    //io.println("Hi, {s}", 123);

    io.println("value: {d}", add(1, 3));
}

fn add(a: i64, b: i64) i64 {
    return a + b;
}