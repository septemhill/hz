import "io"

error SampleError {
    CodegenError,
}

fn on_error() void {
    io.println("defer! 1 cleanup called - error occurred");
}

fn on_error2() void {
    io.println("defer! 2 cleanup called - error occurred");
}

fn test_defer_bang() void! {
    defer! on_error();
    defer! on_error2();
    io.println("test_defer_bang body");

    try codegenError();
    io.println("unreachable")
}

fn codegenError() void! {
    return SampleError.CodegenError;
}

fn main() i64! {
    try test_defer_bang();
    io.println("main done");
    return 0;
}
