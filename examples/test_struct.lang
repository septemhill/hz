import "io"

struct Base {
    name: []const u8,
    age: i32,
    married: bool,

    pub fn new(name: []const u8, age: i32, married: bool) Base {
        return Base{ name, age, married };
    }
}

fn main() void {
    {
        var a: Base = Base.new("Septem", 123, true);

        //a.name[0] = 'c'; // Invalid
        a.age = 999;

        io.println(a.name);
        io.println(a.age);
        io.println(a.married);
    }

    {
        var b: Base = Base{ name: "Septem", age: 123, married: true };

        b.name = "Hazel"; // Valid
        io.println(b.name);
        io.println(b.age);
        io.println(b.married);
    }

    {
        const c = Base{ name: "Septem", age: 123, married: true };
        io.println(c.name);
        io.println(c.age);
        io.println(c.married);
    }

    {
        const d = Base.new("Septem", 123, true);
        io.println(d.name);
        io.println(d.age);
        io.println(d.married);
    }
}