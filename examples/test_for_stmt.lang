import "io"

fn main() i64 {
    for (1..10) |v| {
        io.println(v);
    }

    const c = [3]u8{'a', 'b', 'c'};
    for (c) |k, v| {
        io.println(k);
        io.println(v);
    }

    // Ignore indexs
    for (c) |_, v| {
        io.println(v);
    }

    // Ignore values
    for (c) |k, _| {
        io.println(k);
    }

    var f = Iter { i: 0 };

    for (f.next()) |e| {
        io.println(e);
    }

    for {
        io.println("infinite loop");
    }

    outer: for (1..10) |v| {
        for (1..100) |b| {
            break outer;
        }
    }

    for (2 > 1) {
        io.println("true expression");
    }

    return 0;
}

struct Iter {
    i: u8,

    pub fn next(self: *Self) ?u8 {
        if (self.i < 10) {
            const t = self.i;
            self.i += 1;
            return t;
        }
        return null;
    }
    
}