import "io"

fn main() {
    for (1..10) |v| {
        io.println(v);
    }

    const c = [3]u8{'a', 'b', 'c'};
    for (c) |elem| {
        io.println(elem);
    }

    var f = Iter { i: 0 };

    for (iter.next()) |e| {
        io.println(e);
    }
}

struct Iter {
    i: u8,

    pub fn next(self: *Self) ?u8 {
        if (self.i < 10) {
            const t = self.i;
            self.i += 1;
            return t;
        }
        return null;
    }
    
}