import "io"

interface ServiceCore {
    do_something() void,
}

interface ServiceExtra {
    do_something_else() void,
}

interface Service {
    ServiceCore,
    ServiceExtra,
}

struct Compose<T> {
    inner: T,
    number: i32,
    age: u16,

    fn new(v: T) Compose<T> {
        return Compose<T>{
            inner: v,
        };
    }

    fn map<F>(self: *Self, f: fn(T) F) F {
        return f(self.inner);
    }

    impl Service {
        fn do_something(self: Self) void {
            io.println("do something");
        }

        fn do_something_else(self: Self) void {
            io.println("do something else");
        }
    }
}

fn transition_i32(i: u8) i32 {
    return i32(i);
}

fn transition_u16(i: u8) u16 {
    return u16(i) + 200;
}

fn main() void {
    const comp = Compose<u8>.new(100);
    io.println("composed int: {d}", comp.inner);

    const t1 = comp.map(transition_i32);
    io.println("after map: {d}", t1);

    const t2 = comp.map(transition_u16);
    io.println("after map: {d}", t2);

    service_infc(comp);

    return;
}

fn service_infc<T: Service>(v: T) void {
    v.do_something();
    v.do_something_else();
}
