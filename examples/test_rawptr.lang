// Test rawptr type
import "io"

// Declare external C functions for memory allocation using rawptr
external cdecl malloc(size: u64) rawptr;
external cdecl free(ptr: rawptr) void;

fn main() i32 {
    io.println("=== RawPtr Test ===");
    
    // Test 1: Allocate memory with malloc
    io.println("Test 1: Allocating 8 bytes...");
    const ptr: rawptr = malloc(8);
    
    // Check if allocation succeeded using is_not_null
    if (is_not_null(ptr)) {
        io.println("  Allocation: SUCCESS");
        free(ptr);
        io.println("  Freed");
    } else {
        io.println("  Allocation: FAILED!");
        return 1;
    }
    
    // Test 2: Test is_null with null
    io.println("Test 2: Testing is_null with null...");
    const null_ptr: rawptr = null;
    if (is_null(null_ptr)) {
        io.println("  is_null(null): true (correct)");
    } else {
        io.println("  is_null(null): false (ERROR!)");
        return 1;
    }
    
    // Test 3: Test is_not_null with valid pointer
    io.println("Test 3: Testing is_not_null with valid pointer...");
    if (is_not_null(ptr)) {
        io.println("  is_not_null(valid): true (correct)");
    } else {
        io.println("  is_not_null(valid): false (ERROR!)");
        return 1;
    }
    
    io.println("");
    io.println("All tests passed!");
    return 0;
}
