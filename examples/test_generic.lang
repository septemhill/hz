import "io"

struct Compose<T> {
    inner: T,

    fn new(v: T) Compose<T> {
        return Compose<T>{
            inner: v,
        };
    }

    fn map<F>(self: *Self, f: fn(T) F) F {
        return f(self.inner);
    }
}

struct Data {
    age: i32,
}

fn add<T>(a: T, b: T) T {
    return a + b;
}

fn transition_i32(i: u8) i32 {
    return i32(i);
}

fn transition_u16(i: u8) u16 {
    return u16(i) + 200;
}

fn main() void {
    const a: i32 = 1;
    const b: i32 = 2;

    io.println("int value: {d}", add(a, b));

    const c: f64 = 22.11;
    const d: f64 = 44.77;

    io.println("float value: {f}", add(c, d));

    const comp = Compose<u8>.new(100);
    io.println("composed int: {d}", comp.inner);

    const t1 = comp.map(transition_i32);
    io.println("after map: {d}", t1);

    const t2 = comp.map(transition_u16);
    io.println("after map: {d}", t2);
                                                    
    const comp_f = Compose<f64>.new(3.14);
    io.println("composed float: {f}", comp_f.inner);

    const vv = Compose<Data>.new(Data{age: 100});
    io.println("composed struct: {d}", vv.inner.age);

    return;
}