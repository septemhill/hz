struct PostgresConfig {
    host: String,
    port: i16,
    username: String,
    password: String,
    database: String,
}

struct RedisConfig {
    host: String,
    port: i16,
}

enum Status {
    Todo,
    InProgress,
    Review,
    Verify,
    Done,
}

error ParseError {
    InvalidStatus,
}

enum ActiveStatus {
    InProgress,
    Review,
    Verify,

    fn parse(s: Status) ActiveStatus! {
        switch (s) {
            Status.InProgress => {
                return ActiveStatus.InProgress;
            }
            Status.Review => {
                return ActiveStatus.Review;
            }
            Status.Verify => {
                return ActiveStatus.Verify;
            }
            _ => {
                return ParseError.InvalidStatus;
            }
        }
    }
}

struct Config {
    postgres: PostgresConfig,
    redis: RedisConfig,

    pub fn parse(configPath: String) Config {
        return Config {
            postgres: PostgresConfig {
                host: "localhost",
                port: 5432,
                username: "postgres",
                password: "postgres",
                database: "postgres"
            },
            redis: RedisConfig {
                host: "localhost",
                port: 6379
            }
        };
    }

    pub fn postgresHost(self: Config) String {
        return self.postgres.host;
    }
}

// Separate function to create config - avoids type inference issues
fn create_config() Config {
    return Config.parse("config.json");
}

fn main() i64! {
    const config = create_config();

    io.println(config.postgres.host);

    return 0;
}
