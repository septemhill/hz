// MallocAllocator - Base allocator using system malloc/free

import "io";

// External C functions for memory allocation
external cdecl malloc(size: usize) *void;
external cdecl free(ptr: *void) void;

// Allocate memory
pub fn malloc_allocator_alloc(size: usize) *void {
    return malloc(size);
}

// Free memory  
pub fn malloc_allocator_free(ptr: *void) void {
    free(ptr);
}
