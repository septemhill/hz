// Testing library

/// Assert that a condition is true, panic with message if false
pub fn assert(condition: bool, msg: String) {
    if !condition {
        panic(msg);
    }
    return;
}

/// Assert that two i64 values are equal
pub fn assert_eq_i64(actual: i64, expected: i64, msg: String) {
    if actual != expected {
        panic(msg);
    }
    return;
}

/// Assert that two i64 values are not equal
pub fn assert_ne_i64(actual: i64, expected: i64, msg: String) {
    if actual == expected {
        panic(msg);
    }
    return;
}

